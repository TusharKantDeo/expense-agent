# Google Cloud Project Configuration
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-east1
GOOGLE_CLOUD_PROJECT_NUMBER=your-gcp-project-number

# Agent Engine Configuration
REASONING_ENGINE_ID=your-engine-id
# Example format: projects/<project-number>/locations/us-east1/reasoningEngines/<engine-id>
AGENT_RUNTIME_ID=projects/your-gcp-project-number/locations/us-east1/reasoningEngines/your-engine-id

# SDK configuration flags
GOOGLE_GENAI_USE_ENTERPRISE=True

# Optional GCS telemetry / log bucket configuration
# LOGS_BUCKET_NAME=gs://your-gcs-bucket-name
